# Azure AI Foundry Project Endpoint
# Get from: terraform output FOUNDRY_PROJECT_ENDPOINT
# Or from: Azure Portal → AI Foundry → Project → Settings → Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project

# Model deployment name
# Deployed by Terraform as gpt-4.1
FOUNDRY_MODEL=gpt-4.1
