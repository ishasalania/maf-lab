{
    "name": "MAF Workshop",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/azure-cli:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers-extra/features/terraform:1": {}
    },
    "postCreateCommand": "pip install -r requirements.txt && cp -n .env.example .env 2>/dev/null || true",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "github.copilot",
                "github.copilot-chat",
                "hashicorp.terraform",
                "ms-azuretools.vscode-azureresourcegroups"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": true
            }
        }
    },
    "forwardPorts": [],
    "remoteUser": "vscode"
}
